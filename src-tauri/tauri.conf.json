{
  "$schema": "https://schema.tauri.app/config/2",
  "version": "0.1.0",
  "identifier": "com.chico.modo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "productName": "MoDo",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoDo",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false
      },
      {
        "label": "quick-capture",
        "title": "Quick Drop",
        "url": "quick.html",
        "width": 640,
        "height": 224,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
